    "@shopify/hydrogen": "2026.4.2",
    "@shopify/remix-oxygen": "3.0.3",
    "clsx": "^1.2.1",
    "graphql": "^16.6.0",
    "graphql-tag": "^2.12.6",
    "isbot": "^5.1.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intersection-observer": "^9.4.1",
    "react-router": "7.14.0",
    "react-use": "^17.4.0",
    "schema-dts": "^1.1.0",
    "tiny-invariant": "^1.2.0",
    "typographic-base": "^1.0.4"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.2",
